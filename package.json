{
  "name": "froozo-pos",
  "version": "1.0.0",
  "description": "Froozo Cafe POS Management System",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"nodemon server/index.js\" \"cd client && npm run dev\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm run dev",
    "seed": "node server/seed/seedData.js",
    "install-all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "autoprefixer": "^10.5.2",
    "axios": "^1.18.1",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "lucide-react": "^1.22.0",
    "mongodb": "^7.4.0",
    "mongoose": "^8.0.3",
    "postcss": "^8.5.16",
    "qrcode.react": "^4.2.0",
    "react-router-dom": "^7.18.0",
    "recharts": "^3.9.0",
    "socket.io": "^4.8.3",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
